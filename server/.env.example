# Render usually provides PORT automatically.
PORT=3001

# Bind to all interfaces for local LAN access and cloud platforms.
HOST=0.0.0.0

# Optional: set this to your Vercel frontend origin in production.
# Example:
# CORS_ORIGIN=https://your-frontend.vercel.app
CORS_ORIGIN=

# Optional: SQLite database file path. Relative paths are resolved from server/.
DATABASE_PATH=./data/wardrobe.sqlite

# Required in Render for auth tokens. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-secret

# Optional: JWT token lifetime.
JWT_EXPIRES_IN=7d
